# ─── Single Account ──────────────────────────────────────────────────────────
# Just one line and you're done:
DISCORD_TOKEN=your_token_here

# ─── Multi-Account ───────────────────────────────────────────────────────────
# Match the "id" fields from your config.json:
#
#   config.json has:  { "id": "main" }
#   .env should have: GHOST_TOKEN_MAIN=token_for_main
#
#   config.json has:  { "id": "alt" }
#   .env should have: GHOST_TOKEN_ALT=token_for_alt
#
# Examples:
# GHOST_TOKEN_MAIN=your_main_token_here
# GHOST_TOKEN_ALT=your_alt_token_here
#
# You can also use env vars without config.json at all:
#   GHOST_TOKEN_FRIEND=...   →  auto-creates account with id "friend"
#   GHOST_TOKEN_BOT=...      →  auto-creates account with id "bot"

# ─── Optional ───────────────────────────────────────────────────────────────
# PREFIX=.   (overrides the prefix from config.json)
