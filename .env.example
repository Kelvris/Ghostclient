# ─── Single Account ──────────────────────────────────────────────────────────
# Just one line and you're done:
DISCORD_TOKEN=your_token_here

# ─── Multi-Account ───────────────────────────────────────────────────────────
# Numbered tokens — that's it. No IDs, no config changes.
# Accounts will be named "account1", "account2", etc.
#
# TOKEN_1=your_first_token
# TOKEN_2=your_second_token
# TOKEN_3=your_third_token
# (add as many as you want)
